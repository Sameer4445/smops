# ════════════════════════════════════════════════════════════════
# Student Management System – Root Environment Variables
# Copy this to .env (never commit .env to version control)
# ════════════════════════════════════════════════════════════════

# ─── Backend ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_VERSION=1.0.0
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# ─── Frontend ─────────────────────────────────────────────────
# Leave empty to use Vite's proxy in development
VITE_API_URL=

# ─── Azure Container Registry ─────────────────────────────────
ACR_NAME=youracrname
DOCKER_REGISTRY_SERVICE_CONNECTION=acr-service-connection

# ─── Azure App Service ────────────────────────────────────────
AZURE_SUBSCRIPTION=azure-service-connection
WEB_APP_NAME=sms-app-prod
